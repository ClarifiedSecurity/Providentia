- if @networks.any?
  - @networks.group_by { it.actor.root }.each do |root_actor, networks|
    .py-4.text-center.text-xl.font-semibold= render ActorChip::Component.new(root_actor)
    .pb-5
      .border-t.border-gray-200.dark:border-gray-600

    = render NetworkListing::Component.new(networks, context_actor: root_actor)

- else
  = render Emptylisting::Component.new(klass: Network) do
    - if allowed_to?(:create?, Network.new(exercise: @exercise))
      = link_to "Create the first network", [:new, @exercise, :network], class: 'text-indigo-600 hover:text-indigo-900 dark:text-indigo-400 dark:hover:text-indigo-200'
      to get started
