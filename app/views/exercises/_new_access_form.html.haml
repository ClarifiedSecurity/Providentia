= simple_form_for(@access_form, url: [@exercise, :role_bindings], html: { autocomplete: "off" }) do |form|
  = form.input :role, collection: roles_for_select, include_blank: false, input_html: { data: { controller: 'select' } }

  = form.input :actor_id, collection: sorted_tree_options(authorized_scope(@exercise.actors.roots)), include_blank: true, input_html: { data: { controller: 'select' } }

  %fieldset.mt-2
    %label.block.font-bold.text-gray-700.dark:text-gray-200.my-1
      Access assignment mode
      %small.font-light which field from SSO determines access

    .inline-flex.-space-x-0.divide-x.divide-gray-400.overflow-hidden.rounded-lg.border.border-gray-400.shadow-sm
      = form.label "assignment_mode_email", class: 'inline-flex items-center px-3 py-2 cursor-pointer text-center text-sm font-medium text-gray-600 shadow-sm bg-white hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-200 dark:hover:bg-gray-400 has-[:checked]:bg-blue-200 has-[:checked]:dark:bg-blue-600' do
        User e-mail
        = form.radio_button "assignment_mode", :email, class: 'hidden', id: "access_assignment_mode_email"

      = form.label "assignment_mode_resource", class: 'inline-flex items-center px-3 py-2 cursor-pointer text-center text-sm font-medium text-gray-600 shadow-sm bg-white hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-200 dark:hover:bg-gray-400 has-[:checked]:bg-blue-200 has-[:checked]:dark:bg-blue-600' do
        User resource
        = form.radio_button "assignment_mode", :resource, class: 'hidden', id: "access_assignment_mode_resource"

  .mt-2= form.input :assignment_target, wrapper_class: 'mt-2'
  .mt-2= form.button :submit, 'Save', class: 'form-submit'



